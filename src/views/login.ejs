<%- include("partials/header", { title: "Iniciar sesión" }) %>
<%- include("partials/messages") %>

<section class="page-hero auth-shell">
  <div class="page-hero-content">
    <span class="eyebrow">Acceso</span>
    <h1 class="page-title">Iniciar sesión</h1>
    <p class="page-lead">Entrá a tu cuenta para ver personajes, administrar tu seguridad y acceder a las funciones privadas del panel.</p>
  </div>
</section>

<section class="auth-shell">
  <article class="form-card">
    <form method="post" action="/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <label for="login">Usuario</label>
        <input id="login" type="text" name="login" autocomplete="username" required>
      </div>
      <div>
        <label for="password">Contraseña</label>
        <input id="password" type="password" name="password" autocomplete="current-password" required>
      </div>
      <button type="submit">Entrar</button>
    </form>

    <p class="form-help">
      ¿No tenés cuenta? <a href="/register">Registrate</a>.
      Si olvidaste tu clave, podés <a href="/forgot-password">recuperar el acceso</a>.
    </p>
  </article>
</section>

<%- include("partials/footer") %>
