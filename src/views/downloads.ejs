<%- include("partials/header", { title: "Descargas" }) %>
<%- include("partials/messages") %>

<section class="page-hero">
  <div class="page-hero-content">
    <span class="eyebrow">Descargas</span>
    <h1 class="page-title">Archivos del juego</h1>
    <p class="page-lead">Descargá el cliente, el patch y el updater desde una sección más ordenada y clara.</p>
  </div>
</section>

<section class="downloads-grid">
  <article class="download-card">
    <div class="card-eyebrow">Cliente</div>
    <h3><%= downloads.client.label %></h3>
    <p>Archivo base para comenzar a jugar.</p>
    <div class="content-actions">
      <a class="button-link" href="<%= downloads.client.url %>">Descargar</a>
    </div>
  </article>

  <article class="download-card">
    <div class="card-eyebrow">Patch</div>
    <h3><%= downloads.patch.label %></h3>
    <p>Actualización recomendada para tener el contenido al día.</p>
    <div class="content-actions">
      <a class="button-link" href="<%= downloads.patch.url %>">Descargar</a>
    </div>
  </article>

  <article class="download-card">
    <div class="card-eyebrow">Updater</div>
    <h3><%= downloads.updater.label %></h3>
    <p>Herramienta para mantener el cliente sincronizado con el servidor.</p>
    <div class="content-actions">
      <a class="button-link" href="<%= downloads.updater.url %>">Descargar</a>
    </div>
  </article>
</section>

<%- include("partials/footer") %>
