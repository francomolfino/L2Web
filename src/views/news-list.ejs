<%- include("partials/header", { title: "Noticias" }) %>
<%- include("partials/messages") %>

<section class="page-hero">
  <div class="page-hero-content">
    <span class="eyebrow">Noticias</span>
    <h1 class="page-title">Novedades del servidor</h1>
    <p class="page-lead">Anuncios, actualizaciones y comunicados publicados para la comunidad.</p>
  </div>
</section>

<section class="stack">
  <% if (!newsList || !newsList.length) { %>
    <div class="empty-state">No hay noticias publicadas.</div>
  <% } else { %>
    <div class="news-grid">
      <% newsList.forEach(article => { %>
        <article class="news-item">
          <h2><a href="/news/<%= article.slug %>"><%= article.title %></a></h2>
          <p class="news-date"><%= article.formattedDate %></p>
          <p><%= article.summary %></p>
        </article>
      <% }) %>
    </div>
  <% } %>

  <div class="content-actions">
    <a class="button-link button-link-secondary" href="/">Volver al inicio</a>
  </div>
</section>

<%- include("partials/footer") %>
