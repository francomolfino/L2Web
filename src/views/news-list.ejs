<%- include("partials/header", { title: "Noticias", bodyClass: "content-page" }) %>
<%- include("partials/nav") %>
<%- include("partials/messages") %>

<main class="content-showcase news-showcase" aria-label="Noticias">
  <section class="content-hero-panel" aria-labelledby="news-title">
    <h1 id="news-title">Noticias</h1>
    <p>Actualizaciones, anuncios y novedades del servidor.</p>
  </section>

  <section class="account-panel content-panel content-panel-large" aria-labelledby="news-list-title">
    <div class="account-panel-heading">
      <h2 id="news-list-title">Ultimas noticias</h2>
    </div>

    <% if (!newsList || !newsList.length) { %>
      <div class="account-empty">No hay noticias publicadas.</div>
    <% } else { %>
      <div class="public-news-grid">
        <% newsList.forEach((article, index) => { %>
          <article class="public-news-card">
            <a class="public-news-image" href="/news/<%= article.slug %>" style="background-image: url('/conquer/images/news-img-small_<%= (index % 2) + 1 %>_v1.jpg');">
              <span><%= article.formattedDate %></span>
            </a>
            <div class="public-news-content">
              <h3><a href="/news/<%= article.slug %>"><%= article.title %></a></h3>
              <p><%= article.summary %></p>
              <a href="/news/<%= article.slug %>" class="button button-small">Leer mas</a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<%- include("partials/footer") %>
