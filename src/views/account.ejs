<%- include("partials/header", { title: "Mi cuenta" }) %>
<%- include("partials/messages") %>

<section class="page-hero">
  <div class="page-hero-content">
    <span class="eyebrow">Panel de cuenta</span>
    <h1 class="page-title">Cuenta: <%= account?.login || login %></h1>
    <p class="page-lead">Revisá los datos principales de la cuenta, el estado del servidor y el resumen de personajes asociados.</p>

    <div class="hero-meta">
      <span class="status-pill <%= status && status.online ? "status-online" : "status-offline" %>">
        <%= status && status.online ? "Servidor online" : "Servidor offline" %>
      </span>
      <span class="meta-pill"><strong>Email:</strong> <%= account?.email || "-" %></span>
    </div>
  </div>
</section>

<section class="detail-grid">
  <article class="detail-card">
    <div class="section-heading">
      <h2>Datos de la cuenta</h2>
    </div>
    <ul class="detail-list">
      <li><strong>Usuario</strong><span><%= account?.login || login %></span></li>
      <li><strong>Email</strong><span><%= account?.email || "-" %></span></li>
      <li><strong>Fecha de creación</strong><span><%= account?.formattedCreatedTime || "-" %></span></li>
    </ul>
    <div class="content-actions">
      <a class="button-link button-link-secondary" href="/change-password">Cambiar contraseña</a>
    </div>
  </article>

  <article class="detail-card">
    <div class="section-heading">
      <h2>Resumen</h2>
    </div>
    <ul class="detail-list">
      <li><strong>Estado del servidor</strong><span><%= status && status.online ? "Online" : "Offline" %></span></li>
      <li><strong>Personajes</strong><span><%= characters?.length || 0 %></span></li>
      <li><strong>Acceso</strong><span>Cuenta autenticada</span></li>
    </ul>
  </article>
</section>

<section class="stack">
  <div class="section-heading">
    <h2>Personajes</h2>
  </div>

  <% if (!characters || !characters.length) { %>
    <div class="empty-state">No hay personajes en esta cuenta.</div>
  <% } else { %>
    <div class="char-grid">
      <% characters.forEach(char => { %>
        <article class="char-card">
          <h3><%= char.char_name %></h3>
          <ul class="detail-list">
            <li><strong>Título</strong><span><%= char.title || "-" %></span></li>
            <li><strong>Nivel</strong><span><%= char.level %></span></li>
            <li><strong>Clase</strong><span><%= char.class_name %></span></li>
            <li><strong>Estado</strong><span><%= char.online_label %></span></li>
            <li><strong>Clan</strong><span><%= char.clan_name !== "-" ? char.clan_name : "Sin clan" %></span></li>
            <li><strong>Alianza</strong><span><%= char.ally_name !== "-" ? char.ally_name : "Sin alianza" %></span></li>
            <li><strong>PvP</strong><span><%= char.pvpkills %></span></li>
            <li><strong>PK</strong><span><%= char.pkkills %></span></li>
            <li><strong>Karma</strong><span><%= char.karma %></span></li>
            <li><strong>Creado</strong><span><%= char.formattedCreateDate || "-" %></span></li>
            <li><strong>Tiempo online</strong><span><%= char.online_time_formatted || "-" %></span></li>
          </ul>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include("partials/footer") %>
