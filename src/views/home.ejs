<%- include("partials/header", { title: "Inicio", bodyClass: "home-page" }) %>
<%- include("partials/messages") %>

<section class="home-compact">

  <div class="home-main-grid">
    <section class="stack">

      <% if (!latestNews || !latestNews.length) { %>
        <div class="empty-state">No hay noticias publicadas.</div>
      <% } else { %>
        <div class="news-grid compact-news-grid home-news-card">
          <h2 class="home-news-title"><a href="/news">NOVEDADES</a></h2>
          <% latestNews.forEach(article => { %>
            <article class="news-item">
              <h3><a href="/news/<%= article.slug %>"><%= article.title %></a></h3>
              <p><%= article.summary %></p>
              <p class="news-date"><%= article.formattedDate %></p>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>

    <div class="home-side-column">
      <article class="status-panel home-rankings-card">
        <div class="home-rankings-grid">
          <section class="home-ranking-list">
            <div class="section-heading">
              <h2><a href="/rankings">Top PvP</a></h2>
            </div>

            <% if (!topPvp || !topPvp.length) { %>
              <div class="empty-state">No hay datos disponibles.</div>
            <% } else { %>
              <ol>
                <% topPvp.forEach(row => { %>
                  <li class="rank-entry">
                    <strong><%= row.char_name %></strong> <span class="muted"><%= row.class_name %> | PvP's <%= row.pvpkills %></span>
                  </li>
                <% }) %>
              </ol>
            <% } %>
          </section>

          <section class="home-ranking-list">
            <div class="section-heading">
              <h2><a href="/rankings">Top PK</a></h2>
            </div>

            <% if (!topPk || !topPk.length) { %>
              <div class="empty-state">No hay datos disponibles.</div>
            <% } else { %>
              <ol>
                <% topPk.forEach(row => { %>
                  <li class="rank-entry">
                    <strong><%= row.char_name %></strong> <span class="muted"><%= row.class_name %> | PK's <%= row.pkkills %></span>
                  </li>
                <% }) %>
              </ol>
            <% } %>
          </section>
        </div>
      </article>
    </div>
  </div>
</section>

<%- include("partials/footer") %>
