<%- include("partials/header", { title: "Inicio" }) %>
<%- include("partials/nav") %>
<%- include("partials/messages") %>

<h1>L2Web</h1>

<p>
  Estado del servidor:
  <% if (status.online) { %>
    <strong>Online</strong>
  <% } else { %>
    <strong>Offline</strong>
  <% } %>
</p>

<p><strong>Players online:</strong> <%= onlinePlayers %></p>

<h2>Top 5 PvP</h2>
<% if (!topPvp.length) { %>
  <p>No hay datos.</p>
<% } else { %>
  <ol>
    <% topPvp.forEach(row => { %>
      <li>
        <strong><%= row.char_name %></strong>
        - PvP: <%= row.pvpkills %>
        - Level: <%= row.level %>
        - Clase: <%= row.class_name %>
        - Clan: <%= row.clan_name %>
      </li>
    <% }) %>
  </ol>
<% } %>

<h2>Top 5 PK</h2>
<% if (!topPk.length) { %>
  <p>No hay datos.</p>
<% } else { %>
  <ol>
    <% topPk.forEach(row => { %>
      <li>
        <strong><%= row.char_name %></strong>
        - PK: <%= row.pkkills %>
        - Level: <%= row.level %>
        - Clase: <%= row.class_name %>
        - Clan: <%= row.clan_name %>
      </li>
    <% }) %>
  </ol>
<% } %>

<p><a href="/rankings">Ver rankings detallados</a></p>

<%- include("partials/footer") %>