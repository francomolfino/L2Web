<%- include("partials/header", { title: "Inicio" }) %>
<%- include("partials/messages") %>

<section class="home-compact">
  <div class="home-intro">
    <h1 class="home-title">L2Web</h1>
    <p class="home-subtitle">Noticias del servidor y estado actual en una portada simple y directa.</p>
  </div>

  <div class="home-top-row">
    <article class="status-panel">
      <div class="section-heading">
        <h2>Estado del servidor</h2>
      </div>
      <div class="status-row">
        <span class="status-pill <%= status && status.online ? "status-online" : "status-offline" %>">
          <%= status && status.online ? "Online" : "Offline" %>
        </span>
        <span class="meta-pill"><strong>Online:</strong> <%= onlinePlayers %> jugadores</span>
      </div>
    </article>
  </div>
</section>

<section class="stack">
  <div class="section-heading">
    <h2>Noticias</h2>
    <a href="/news">Ver todas</a>
  </div>

  <% if (!latestNews || !latestNews.length) { %>
    <div class="empty-state">No hay noticias publicadas.</div>
  <% } else { %>
    <div class="news-grid compact-news-grid">
      <% latestNews.forEach(article => { %>
        <article class="news-item">
          <h3><a href="/news/<%= article.slug %>"><%= article.title %></a></h3>
          <p class="news-date"><%= article.formattedDate %></p>
          <p><%= article.summary %></p>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<section class="ranking-grid">
  <article class="rank-item">
    <div class="section-heading">
      <h2>Top PvP</h2>
      <a href="/rankings">Ranking completo</a>
    </div>

    <% if (!topPvp || !topPvp.length) { %>
      <div class="empty-state">No hay datos disponibles.</div>
    <% } else { %>
      <ol>
        <% topPvp.forEach(row => { %>
          <li class="rank-entry">
            <strong><%= row.char_name %></strong><br>
            <span class="muted"><%= row.class_name %> | Nivel <%= row.level %> | PvP <%= row.pvpkills %> | Clan <%= row.clan_name %></span>
          </li>
        <% }) %>
      </ol>
    <% } %>
  </article>

  <article class="rank-item">
    <div class="section-heading">
      <h2>Top PK</h2>
      <a href="/rankings">Ranking completo</a>
    </div>

    <% if (!topPk || !topPk.length) { %>
      <div class="empty-state">No hay datos disponibles.</div>
    <% } else { %>
      <ol>
        <% topPk.forEach(row => { %>
          <li class="rank-entry">
            <strong><%= row.char_name %></strong><br>
            <span class="muted"><%= row.class_name %> | Nivel <%= row.level %> | PK <%= row.pkkills %> | Clan <%= row.clan_name %></span>
          </li>
        <% }) %>
      </ol>
    <% } %>
  </article>
</section>

<%- include("partials/footer") %>
