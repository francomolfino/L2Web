<%- include("partials/header", { title: article.title, bodyClass: "content-page" }) %>
<%- include("partials/nav") %>
<%- include("partials/messages") %>

<main class="content-showcase news-showcase" aria-label="Noticia">
  <section class="content-hero-panel" aria-labelledby="article-title">
    <h1 id="article-title"><%= article.title %></h1>
    <p><%= article.formattedDate %></p>
  </section>

  <article class="account-panel content-panel content-panel-large public-article">
    <% article.body.split("\n").forEach(paragraph => { %>
      <% if (paragraph.trim()) { %>
        <p><%= paragraph %></p>
      <% } %>
    <% }) %>

    <a href="/news" class="button button-small">Volver a noticias</a>
  </article>
</main>

<%- include("partials/footer") %>
