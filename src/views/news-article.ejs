<%- include("partials/header", { title: article.title }) %>
<%- include("partials/messages") %>

<section class="page-hero">
  <div class="page-hero-content">
    <span class="eyebrow">Noticia</span>
    <h1 class="page-title"><%= article.title %></h1>
    <p class="page-lead"><%= article.formattedDate %></p>
  </div>
</section>

<article class="section-card article-body">
  <% article.body.split("\n").forEach(paragraph => { %>
    <% if (paragraph.trim()) { %>
      <p><%= paragraph %></p>
    <% } %>
  <% }) %>

  <div class="content-actions">
    <a class="button-link button-link-secondary" href="/news">Volver a noticias</a>
    <a class="button-link button-link-secondary" href="/">Ir al inicio</a>
  </div>
</article>

<%- include("partials/footer") %>
