<%- include("partials/header", { title: "Recuperar contraseña" }) %>
<%- include("partials/messages") %>

<section class="page-hero auth-shell">
  <div class="page-hero-content">
    <span class="eyebrow">Recuperación</span>
    <h1 class="page-title">Recuperar contraseña</h1>
    <p class="page-lead">Ingresá tu usuario y te enviaremos el enlace para restablecer el acceso a tu cuenta.</p>
  </div>
</section>

<section class="auth-shell">
  <article class="form-card">
    <form method="post" action="/forgot-password">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div>
        <label for="login">Usuario</label>
        <input id="login" type="text" name="login" required>
      </div>
      <button type="submit">Enviar enlace</button>
    </form>
  </article>
</section>

<%- include("partials/footer") %>
