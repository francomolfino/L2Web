<nav class="top-nav">
  <div class="nav-left">
    <a href="/">Inicio</a>
    <a href="/info">Servidor</a>
    <a href="/downloads">Descargas</a>
    <a href="/rankings">Rankings</a>
    <a href="/news">Noticias</a>
  </div>

  <div class="nav-right">
    <% if (user) { %>
      <span class="nav-user-text"><strong><%= user.login %></strong></span>
      <a href="/account">Cuenta</a>

      <form method="post" action="/logout" class="inline-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
