<%- include("partials/header", { title: "Restablecer contraseña" }) %>
<%- include("partials/messages") %>

<section class="page-hero auth-shell">
  <div class="page-hero-content">
    <span class="eyebrow">Seguridad</span>
    <h1 class="page-title">Nueva contraseña</h1>
    <p class="page-lead">Elegí una nueva clave para completar la recuperación de tu cuenta.</p>
  </div>
</section>

<section class="auth-shell">
  <article class="form-card">
    <% if (isValidToken) { %>
      <form method="post" action="/reset-password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="token" value="<%= token %>">

        <div>
          <label for="password">Nueva contraseña</label>
          <input id="password" type="password" name="password" autocomplete="new-password" required>
        </div>

        <div>
          <label for="confirmPassword">Confirmar contraseña</label>
          <input id="confirmPassword" type="password" name="confirmPassword" autocomplete="new-password" required>
        </div>

        <button type="submit">Guardar</button>
      </form>
    <% } else { %>
      <div class="empty-state">
        El enlace ya no es válido o expiró. <a href="/forgot-password">Solicitar uno nuevo</a>.
      </div>
    <% } %>
  </article>
</section>

<%- include("partials/footer") %>
