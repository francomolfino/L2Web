<%- include("partials/header", { title: "Rankings" }) %>
<%- include("partials/nav") %>
<%- include("partials/messages") %>

<h1>Rankings</h1>

<p><a href="/">Volver al inicio</a></p>

<hr>

<h2>Ranking PvP</h2>

<% if (!topPvp || !topPvp.length) { %>
  <p>No hay datos.</p>
<% } else { %>
  <ol>
    <% topPvp.forEach((row, index) => { %>
      <li>
        <p><strong>Nombre:</strong> <%= row.char_name %></p>
        <p><strong>Clase:</strong> <%= row.class_name %></p>
        <p><strong>Level:</strong> <%= row.level %></p>
        <p><strong>PvP:</strong> <%= row.pvpkills %></p>
        <p><strong>Clan:</strong> <%= row.clan_name %></p>
      </li>

      <% if (index !== topPvp.length - 1) { %>
        <hr>
      <% } %>
    <% }) %>
  </ol>
<% } %>

<hr>

<h2>Ranking PK</h2>

<% if (!topPk || !topPk.length) { %>
  <p>No hay datos.</p>
<% } else { %>
  <ol>
    <% topPk.forEach((row, index) => { %>
      <li>
        <p><strong>Nombre:</strong> <%= row.char_name %></p>
        <p><strong>Clase:</strong> <%= row.class_name %></p>
        <p><strong>Level:</strong> <%= row.level %></p>
        <p><strong>PK:</strong> <%= row.pkkills %></p>
        <p><strong>Clan:</strong> <%= row.clan_name %></p>
      </li>

      <% if (index !== topPk.length - 1) { %>
        <hr>
      <% } %>
    <% }) %>
  </ol>
<% } %>

<%- include("partials/footer") %>