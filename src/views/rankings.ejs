<%- include("partials/header", { title: "Rankings" }) %>
<%- include("partials/messages") %>

<section class="page-hero">
  <div class="page-hero-content">
    <span class="eyebrow">Competencia</span>
    <h1 class="page-title">Rankings</h1>
    <p class="page-lead">Consultá los personajes destacados del servidor en PvP y PK con una presentación más clara y legible.</p>
  </div>
</section>

<section class="ranking-grid">
  <article class="rank-item">
    <div class="section-heading">
      <h2>Ranking PvP</h2>
    </div>

    <% if (!topPvp || !topPvp.length) { %>
      <div class="empty-state">No hay datos disponibles.</div>
    <% } else { %>
      <ol>
        <% topPvp.forEach(row => { %>
          <li class="rank-entry">
            <strong><%= row.char_name %></strong><br>
            <span class="muted"><%= row.class_name %> | Nivel <%= row.level %> | PvP <%= row.pvpkills %> | Clan <%= row.clan_name %></span>
          </li>
        <% }) %>
      </ol>
    <% } %>
  </article>

  <article class="rank-item">
    <div class="section-heading">
      <h2>Ranking PK</h2>
    </div>

    <% if (!topPk || !topPk.length) { %>
      <div class="empty-state">No hay datos disponibles.</div>
    <% } else { %>
      <ol>
        <% topPk.forEach(row => { %>
          <li class="rank-entry">
            <strong><%= row.char_name %></strong><br>
            <span class="muted"><%= row.class_name %> | Nivel <%= row.level %> | PK <%= row.pkkills %> | Clan <%= row.clan_name %></span>
          </li>
        <% }) %>
      </ol>
    <% } %>
  </article>
</section>

<%- include("partials/footer") %>
