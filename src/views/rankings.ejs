<%- include("partials/header", { title: "Rankings", bodyClass: "content-page" }) %>
<%- include("partials/nav") %>
<%- include("partials/messages") %>

<main class="content-showcase rankings-showcase" aria-label="Rankings">
  <section class="content-hero-panel" aria-labelledby="rankings-title">
    <h1 id="rankings-title">Rankings</h1>
    <p>Los mejores personajes del servidor ordenados por PvP y PK.</p>
  </section>

  <section class="account-panel content-panel content-panel-large" aria-labelledby="ranking-pvp-title">
    <div class="account-panel-heading">
      <h2 id="ranking-pvp-title">Ranking PvP</h2>
    </div>

    <% if (!topPvp || !topPvp.length) { %>
      <div class="account-empty">No hay datos.</div>
    <% } else { %>
      <div class="ranking-table" role="table" aria-label="Ranking PvP">
        <div class="ranking-row ranking-row-head" role="row">
          <span>#</span>
          <span>Nombre</span>
          <span>Clase</span>
          <span>Level</span>
          <span>PvP</span>
          <span>Clan</span>
        </div>
        <% topPvp.forEach((row, index) => { %>
          <div class="ranking-row" role="row">
            <span class="ranking-position"><%= index + 1 %></span>
            <strong><%= row.char_name %></strong>
            <span><%= row.class_name %></span>
            <span><%= row.level %></span>
            <strong class="ranking-points"><%= row.pvpkills %></strong>
            <span><%= row.clan_name %></span>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

  <section class="account-panel content-panel content-panel-large" aria-labelledby="ranking-pk-title">
    <div class="account-panel-heading">
      <h2 id="ranking-pk-title">Ranking PK</h2>
    </div>

    <% if (!topPk || !topPk.length) { %>
      <div class="account-empty">No hay datos.</div>
    <% } else { %>
      <div class="ranking-table" role="table" aria-label="Ranking PK">
        <div class="ranking-row ranking-row-head" role="row">
          <span>#</span>
          <span>Nombre</span>
          <span>Clase</span>
          <span>Level</span>
          <span>PK</span>
          <span>Clan</span>
        </div>
        <% topPk.forEach((row, index) => { %>
          <div class="ranking-row" role="row">
            <span class="ranking-position"><%= index + 1 %></span>
            <strong><%= row.char_name %></strong>
            <span><%= row.class_name %></span>
            <span><%= row.level %></span>
            <strong class="ranking-points"><%= row.pkkills %></strong>
            <span><%= row.clan_name %></span>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
</main>

<%- include("partials/footer") %>
