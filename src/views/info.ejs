<%- include("partials/header", { title: "Informacion del servidor", bodyClass: "content-page" }) %>
<%- include("partials/nav") %>
<%- include("partials/messages") %>

<%
  const rateRows = [
    ["EXP", `x${serverInfo.rates.exp}`],
    ["SP", `x${serverInfo.rates.sp}`],
    ["Adena", `x${serverInfo.rates.adena}`],
    ["Drop", `x${serverInfo.rates.drop}`],
    ["Spoil", `x${serverInfo.rates.spoil}`],
    ["Quest", `x${serverInfo.rates.quest}`]
  ];
  const settingRows = [
    ["Max enchant weapon", serverInfo.settings.maxEnchantWeapon],
    ["Max enchant armor", serverInfo.settings.maxEnchantArmor],
    ["Max enchant jewelry", serverInfo.settings.maxEnchantJewelry],
    ["Safe enchant weapon", serverInfo.settings.safeEnchantWeapon],
    ["Safe enchant armor", serverInfo.settings.safeEnchantArmor],
    ["Safe enchant jewelry", serverInfo.settings.safeEnchantJewelry],
    ["Auto learn skills", serverInfo.settings.autoLearnSkills ? "Si" : "No"],
    ["Subclass sin quest", serverInfo.settings.subclassWithoutQuest ? "Si" : "No"],
    ["Buffer habilitado", serverInfo.settings.bufferEnabled ? "Si" : "No"],
    ["GM Shop habilitado", serverInfo.settings.gmShopEnabled ? "Si" : "No"]
  ];
%>

<main class="content-showcase info-showcase" aria-label="Informacion del servidor">
  <section class="content-hero-panel" aria-labelledby="info-title">
    <h1 id="info-title">Informaci&oacute;n del servidor</h1>
    <p><%= serverInfo.name %> <span><%= serverInfo.chronicle %></span></p>
  </section>

  <section class="account-panel content-panel content-panel-large" aria-labelledby="rates-title">
    <div class="account-panel-heading">
      <h2 id="rates-title">Rates</h2>
    </div>

    <div class="info-card-grid info-card-grid-large">
      <% rateRows.forEach(([label, value]) => { %>
        <div class="info-stat-card">
          <span><%= label %></span>
          <strong><%= value %></strong>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="account-panel content-panel content-panel-large" aria-labelledby="settings-title">
    <div class="account-panel-heading">
      <h2 id="settings-title">Configuraci&oacute;n</h2>
    </div>

    <div class="account-character-grid info-settings-grid">
      <% settingRows.forEach(([label, value]) => { %>
        <div class="account-character-row">
          <span><%= label %></span>
          <strong><%= value %></strong>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="account-panel content-panel content-panel-large" aria-labelledby="extra-title">
    <div class="account-panel-heading">
      <h2 id="extra-title">Informaci&oacute;n adicional</h2>
    </div>

    <% if (!serverInfo.extra || !serverInfo.extra.length) { %>
      <div class="account-empty">No hay informaci&oacute;n adicional.</div>
    <% } else { %>
      <ul class="info-extra-list">
        <% serverInfo.extra.forEach(item => { %>
          <li><%= item %></li>
        <% }) %>
      </ul>
    <% } %>
  </section>
</main>

<%- include("partials/footer") %>
